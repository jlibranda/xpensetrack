# ============================================================
#  XpenseTrack / Cashalo — BACKEND environment variables
#  Copy this file to ".env" and fill in the values.
# ============================================================

# --- REQUIRED ---------------------------------------------------------------
# PostgreSQL connection string (from your DB host: Railway, Supabase, RDS, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME"

# Secret used to sign login tokens. Use a long random string (e.g. `openssl rand -hex 32`).
# If this changes, all users are logged out. Keep it secret.
JWT_SECRET="replace-with-a-long-random-secret"

# Port the API listens on (many hosts set this automatically; default 3001).
PORT=3001

# --- FIRST ADMIN (used only by `npm run db:seed`) ---------------------------
SEED_ADMIN_EMAIL="admin@yourcompany.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_FIRSTNAME="System"
SEED_ADMIN_LASTNAME="Administrator"
SEED_COMPANY_NAME="Your Company Inc."

# --- RECOMMENDED ------------------------------------------------------------
# Public URL of the FRONTEND (used in email links, e.g. password reset).
FRONTEND_URL="https://expenses.yourcompany.com"
NODE_ENV="production"

# One-time admin RECOVERY: on boot, promotes these existing emails to ADMIN.
# Leave blank normally; set + redeploy only if you lock yourself out, then remove.
# BOOTSTRAP_ADMIN_EMAIL="admin@yourcompany.com"

# --- OPTIONAL: Email notifications (pick ONE provider, or leave all blank) ---
# MailerSend
# MAILERSEND_API_KEY=""
# MAILERSEND_FROM="no-reply@yourcompany.com"
# Resend
# RESEND_API_KEY=""
# RESEND_FROM="no-reply@yourcompany.com"
# Display name/color used in emails
# EMAIL_BRAND="Your Company"
# EMAIL_BRAND_COLOR="#1D9E75"
# EMAIL_FROM="no-reply@yourcompany.com"

# --- OPTIONAL: Receipt OCR (leave blank to disable OCR autofill) -------------
# OCR.space API key
# OCRSPACE_API_KEY=""
# Anthropic (AI receipt reading) — ROTATE if the old key was ever exposed.
# ANTHROPIC_API_KEY=""

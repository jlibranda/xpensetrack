generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  employeeNumber String?         @unique
  email          String          @unique
  firstName      String
  lastName       String
  passwordHash   String
  role           Role            @default(EMPLOYEE)
  department     String?
  costCenter     String?
  position       String?
  payrollAccount String?
  isActive       Boolean         @default(true)
  managerId      String?
  manager        User?           @relation("Reports", fields: [managerId], references: [id])
  reports        User[]          @relation("Reports")
  approvalChainId String?
  approvalChain   ApprovalChain? @relation("AssignedChain", fields: [approvalChainId], references: [id])
  expenses       Expense[]       @relation("SubmittedBy")
  approvals      Approval[]
  stepApprovers  ApprovalStepApprover[]
  passwordResets PasswordReset[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

enum Role {
  EMPLOYEE
  MANAGER
  FINANCE
  ADMIN
}

model Expense {
  id            String        @id @default(cuid())
  title         String
  orNumber      String?
  merchant      String?
  description   String?
  amount        Float
  currency      Currency      @default(PHP)
  amountPhp     Float
  category      String
  glCode        String?
  expenseType   String        @default("REIMBURSEMENT")
  receiptId     String?
  receipt       Receipt?      @relation(fields: [receiptId], references: [id])
  costCenter    String?
  expenseDate   DateTime
  submittedById String
  submittedBy   User          @relation("SubmittedBy", fields: [submittedById], references: [id])
  approvals     Approval[]
  status        ExpenseStatus @default(DRAFT)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

enum Currency {
  PHP
  USD
}

enum ExpenseStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  REIMBURSED
  CANCELLED
}

model Receipt {
  id        String    @id @default(cuid())
  data      Bytes
  mimeType  String    @default("image/jpeg")
  filename  String?
  expenses  Expense[]
  createdAt DateTime  @default(now())
}

model Approval {
  id         String         @id @default(cuid())
  expenseId  String
  expense    Expense        @relation(fields: [expenseId], references: [id])
  approverId String
  approver   User           @relation(fields: [approverId], references: [id])
  status     ApprovalStatus @default(PENDING)
  level      Int            @default(1)
  stepOrder  Int            @default(1)
  groupKey   String?
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

// ===== Flexible approval chains (templates) =====
model ApprovalChain {
  id        String          @id @default(cuid())
  name      String          @unique
  mode      ApprovalMode    @default(SEQUENTIAL)
  isActive  Boolean         @default(true)
  steps     ApprovalStep[]
  assignees User[]          @relation("AssignedChain")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

enum ApprovalMode {
  SEQUENTIAL
  ANY_ORDER
}

model ApprovalStep {
  id        String                 @id @default(cuid())
  chainId   String
  chain     ApprovalChain          @relation(fields: [chainId], references: [id], onDelete: Cascade)
  order     Int                    // 1..5
  approvers ApprovalStepApprover[]
  createdAt DateTime               @default(now())
}

// Each row is one approver option within a step. Multiple rows on the same
// step form an OR group: any one of them approving satisfies the step.
model ApprovalStepApprover {
  id         String       @id @default(cuid())
  stepId     String
  step       ApprovalStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  approverId String
  approver   User         @relation(fields: [approverId], references: [id])
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model OrgSettings {
  id                   String   @id @default(cuid())
  companyName          String   @default("My Company")
  defaultCurrency      Currency @default(PHP)
  receiptRequiredAbove Float    @default(500)
  approvalLevels       Int      @default(2)
  primaryColor         String   @default("#1D9E75")
  logoUrl              String?
  wallpaperUrl         String?
  darkMode             Boolean  @default(false)
  categories           String   @default("Cleaning,Education and Training,Entertainment/Meals,Equipment,Facility Maintenance and Repair,Furniture and Fixtures,General Office Expense,Hardware,Miscellaneous,Mobile Device,Non-Capital Small Tools Equipment and Furniture,Office Rent,Parking,Printing,Recruiting,Travel - Air Ticket (International),Travel - Air Ticket (Domestic),Travel - Others,Travel - Hotel (Domestic)")
  categoryGlCodes      String   @default("{}")
  expenseTypes         String   @default("REIMBURSEMENT,CASH_ADVANCE")
  defaultPassword      String   @default("Welcome123")
  accessControlJson    String   @default("{}")
  updatedAt            DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
